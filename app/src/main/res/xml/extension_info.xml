<?xml version="1.0" encoding="utf-8"?>
<ExtensionInfo
    id="ride-replay"
    displayName="@string/extension_name"
    icon="@android:drawable/ic_media_play"
    configurable="true"
    fitFile="false"
    scansDevices="true">

    <!-- scansDevices="true" is REQUIRED for Karoo OS to invoke startScan()
         on our service; without it the virtual sensors never appear in the
         Settings → Sensors → Add Sensor UI. Confirmed by comparing against
         lockevod/Karoo-KPower's extension_info.xml + Hammerhead's sample
         extension, both of which declare it. -->

    <!-- No DataType entries — the extension's role is publishing virtual
         sensor Devices for the Karoo to pair to, not providing data fields. -->

</ExtensionInfo>
